# GitHub Personal Access Token (no scope needed for public data, just enables higher rate limits).
# Without this token: 60 requests/hour. With token: 5000 requests/hour.
# Generate at: https://github.com/settings/tokens
GITHUB_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional: only needed if you re-enable OAuth login flow (currently unused)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback
